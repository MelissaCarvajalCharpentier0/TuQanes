s\": [\n          0.6101637691164852,\n          0.5976795179773854,\n          0.6797709923664123\n        ],\n        \"semantic_type\": \"\",\n        \"description\": \"\"\n      }\n    },\n    {\n      \"column\": \"std\",\n      \"properties\": {\n        \"dtype\": \"number\",\n        \"std\": 0.009602241467633206,\n        \"min\": 0.012470465078400425,\n        \"max\": 0.03848208692788926,\n        \"num_unique_values\": 8,\n        \"samples\": [\n          0.016086949555575925,\n          0.02213486862068233,\n          0.012470465078400425\n        ],\n        \"semantic_type\": \"\",\n        \"description\": \"\"\n      }\n    }\n  ]\n}"}},"metadata":{},"execution_count":15}]},{"cell_type":"markdown","source":["## 5. Búsqueda mínima exigida por el reto"],"metadata":{"id":"mqNmuF7IxZzc"}},{"cell_type":"code","source":["\n","challenge_param_grid = {\n","    \"svc__C\": [0.1, 1, 10],\n","    \"svc__gamma\": [\"scale\", \"auto\", 0.01],\n","    \"svc__class_weight\": [None, \"balanced\"],\n","}\n","\n","grid_search = GridSearchCV(\n","    estimator=baseline_pipeline,\n","    param_grid=challenge_param_grid,\n","    scoring=scoring,\n","    refit=\"f1\",\n","    cv=cv,\n","    n_jobs=-1,\n","    verbose=1,\n","    return_train_score=True,\n","    error_score=\"raise\",\n",")\n","\n","grid_search.fit(X_train, y_train)\n","\n","print(\"Mejores hiperparámetros:\", grid_search.best_params_)\n","print(\"Mejor F1 CV:\", grid_search.best_score_)\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"eJS--V8fxZKI","executionInfo":{"status":"ok","timestamp":1784521575567,"user_tz":360,"elapsed":39854,"user":{"displayName":"Johnny Zaet Aguero","userId":"04963209225801493793"}},"outputId":"fe2f94c9-510f-4819-dd74-81c57d6227d9"},"execution_count":16,"outputs":[{"output_type":"stream","name":"stdout","text":["Fitting 5 folds for each of 18 candidates, totalling 90 fits\n","Mejores hiperparámetros: {'svc__C': 1, 'svc__class_weight': 'balanced', 'svc__gamma': 'scale'}\n","Mejor F1 CV: 0.5703708657701149\n"]}]},{"cell_type":"markdown","source":["\n","## 6. Optuna: recomendado como segunda etapa\n","\n","Optuna **no se descarta**. Para este problema es útil después del grid mínimo porque:\n","\n","- `C` y `gamma` funcionan mejor en escalas logarítmicas continuas.\n","- Permite buscar pesos personalizados para la clase positiva.\n","- Guarda el historial de ensayos y facilita reproducibilidad.\n","- Puede podar ensayos en modelos iterativos, aunque `SVC` no ofrece aprendizaje incremental; por eso aquí el pruning aporta poco.\n","\n","La estrategia recomendada es:\n","\n","1. Ejecutar primero el grid mínimo del reto.\n","2. Usar Optuna para refinar alrededor de rangos amplios.\n","3. Elegir hiperparámetros solo con validación cruzada dentro de `X_train`.\n","4. Evaluar el test una sola vez con el ganador final.\n","\n","> Nota: la optimización de muchos ensayos sobre un dataset pequeño puede sobreajustar la validación cruzada. Por eso se limita el presupuesto y se mantiene el test completamente aislado.\n"],"metadata":{"id":"0GM-qrtRxpLb"}},{"cell_type":"code","source":["\n","RUN_OPTUNA = True\n","N_TRIALS = 60\n","\n","try:\n","    import optuna\n","except ImportError:\n","    optuna = None\n","    print(\"Optuna no está instalado. Ejecute: pip install optuna\")\n","\n","def objective(trial):\n","    C = trial.suggest_float(\"C\", 1e-3, 1e3, log=True)\n","    gamma = trial.suggest_float(\"gamma\", 1e-5, 1e1, log=True)\n","    class_weight_mode = trial.suggest_categorical(\n","        \"class_weight_mode\", [\"none\", \"balanced\", \"custom\"]\n","    )\n","\n","    if class_weight_mode == \"none\":\n","        class_weight = None\n","    elif class_weight_mode == \"balanced\":\n","        class_weight = \"balanced\"\n","    else:\n","        positive_weight = trial.suggest_float(\"positive_weight\", 0.75, 3.0, log=True)\n","        class_weight = {0: 1.0, 1: positive_weight}\n","\n","    pipeline = Pipeline([\n","        (\"imputer\", SimpleImputer(strategy=\"median\")),\n","        (\"scaler\", StandardScaler()),\n","        (\"svc\", SVC(\n","            kernel=\"rbf\",\n","            C=C,\n","            gamma=gamma,\n","            class_weight=class_weight,\n","            probability=False,\n","            cache_size=1000,\n","        )),\n","    ])\n","\n","    result = cross_validate(\n","        pipeline,\n","        X_train,\n","        y_train,\n","        cv=cv,\n","        scoring={\"f1\": \"f1\"},\n","        n_jobs=-1,\n","        return_train_score=False,\n","    )\n","    return float(np.mean(result[\"test_f1\"]))\n","\n","study = None\n","if RUN_OPTUNA and optuna is not None:\n","    sampler = optuna.samplers.TPESampler(seed=RANDOM_STATE)\n","    study = optuna.create_study(direction=\"maximize\", sampler=sampler)\n","    study.optimize(objective, n_trials=N_TRIALS, show_progress_bar=True)\n","\n","    print(\"Mejor F1 CV Optuna:\", study.best_value)\n","    print(\"Mejores parámetros:\", study.best_params)\n","\n","    trials_df = study.trials_dataframe()\n","    trials_df.to_csv(ARTIFACT_DIR / \"optuna_trials.csv\", index=False)\n","    with open(ARTIFACT_DIR / \"optuna_best_params.json\", \"w\", encoding=\"utf-8\") as f:\n","        json.dump(study.best_params, f, indent=2)\n","else:\n","    print(\"Se omitió Optuna.\")\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":1000,"referenced_widgets":["739354233a0e434d81caedfc56482d17","9a569512f57f423a923079bb74606629","d7fc8fc4ccc541f4bb5f69c298407a55","02aaf90a15dd4ce2968f56929d2a6ee9","1eb3a059fa95478a930af97673ce646c","f24c8705b2c14c6b9b223e2473f98fb0","8444354f5c0849efb3ba71c8a0e6554c","2577c1f75a714e26b6fd30537956bb65","2864815057d74f7e9f160ea393c599bb","82af53a0c2914e579821a46800a18181","0215855e28df42cd9d845b99e568b6f4"]},"id":"s5esmaKfxtFj","executionInfo":{"status":"ok","timestamp":1784521715376,"user_tz":360,"elapsed":54751,"user":{"displayName":"Johnny Zaet Aguero","userId":"049632